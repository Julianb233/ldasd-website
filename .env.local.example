# Supabase Configuration
# Get these from: Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (for email redirect links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Stripe Configuration
# Get from: Stripe Dashboard -> Developers -> API keys
# =============================================================================

STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook secret - get from:
# Local: Run `stripe listen --print-secret`
# Production: Dashboard -> Webhooks -> endpoint -> Reveal secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# Stripe Price IDs
# Create products in Stripe Dashboard -> Products, copy Price IDs (price_xxx)
# =============================================================================

# Last Will & Testament ($199 individual, $299 couples)
STRIPE_PRICE_WILL_INDIVIDUAL=price_will_individual_here
STRIPE_PRICE_WILL_COUPLES=price_will_couples_here

# Living Trust ($499 individual, $599 couples)
STRIPE_PRICE_TRUST_INDIVIDUAL=price_trust_individual_here
STRIPE_PRICE_TRUST_COUPLES=price_trust_couples_here

# Power of Attorney ($99, individual only)
STRIPE_PRICE_POA=price_poa_here

# Healthcare Directive ($99, individual only)
STRIPE_PRICE_HEALTHCARE=price_healthcare_here

# Complete Estate Plan bundle ($699 individual, $899 couples)
STRIPE_PRICE_ESTATE_INDIVIDUAL=price_estate_individual_here
STRIPE_PRICE_ESTATE_COUPLES=price_estate_couples_here

# =============================================================================
# Supabase Service Role (for webhooks - bypasses RLS)
# Get from: Supabase Dashboard -> Project Settings -> API
# WARNING: Keep this secret! Never expose in client-side code.
# =============================================================================

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =============================================================================
# Resend (Email receipts)
# Get from: https://resend.com/api-keys
# =============================================================================

RESEND_API_KEY=re_your_api_key_here
